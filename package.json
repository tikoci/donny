{
  "name": "@tikoci/donny",
  "version": "0.1.0",
  "description": "TypeScript library and CLI for MikroTik The Dude network monitoring database (dude.db)",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "donny": "src/cli/index.ts"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "DESIGN.md"
  ],
  "scripts": {
    "check": "bun run lint:biome && bun run lint:typecheck && bun run lint:markdown",
    "lint:biome": "biome check .",
    "lint:typecheck": "tsc --noEmit",
    "lint:markdown": "bunx markdownlint-cli2 '**/*.md'",
    "test": "bun test test/unit/",
    "test:all": "bun test test/unit/",
    "dev": "bun run src/cli/index.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "markdownlint-cli2": "^0.21.0",
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0"
  },
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tikoci/donny.git"
  },
  "keywords": [
    "mikrotik",
    "routeros",
    "dude",
    "network-monitoring",
    "sqlite",
    "cli"
  ]
}
