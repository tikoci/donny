{
  "lspServers": {
    "typescript": {
      "command": "typescript-language-server",
      "args": ["--stdio"],
      "fileExtensions": {
        ".ts": "typescript",
        ".tsx": "typescript"
      }
    },
    "routeros": {
      "command": "node",
      "args": ["scripts\\routeroslsp-launcher.cjs"],
      "fileExtensions": {
        ".rsc": "routeros",
        ".routeros": "routeros",
        ".tikbook": "routeros",
        ".tikbook.rsc": "routeros",
        ".md.rsc": "routeros"
      }
    }
  }
}
